{
  "name": "csv-visualization",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:github": "vite build && gh-pages -d dist",
    "electron:start": "electron .",
    "pack:installer": "electron-builder"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "gh-pages": "^6.3.0",
    "vite": "^7.3.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "text-encoding": "^0.7.0"
  },
  "build": {
    "appId": "com.csv.visualization",
    "productName": "CSV可视化工具",
    "directories": {
      "output": "installer"
    },
    "files": [
      "dist/**/*",
      "main.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "arch": [
        "x64",
        "arm64"
      ]
    },
    "linux": {
      "target": "deb"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}